# =============================================================================
#  Bybit API keys  —  copy this file to ".env" and fill in your own keys.
#  NEVER commit .env. NEVER hardcode keys in code.
# =============================================================================

# --- PAPER backend: "testnet" (default) or "demo" --------------------------
# testnet = Bybit Testnet (faucet funds, can be flaky).
# demo    = Bybit Demo Trading (instant 50k USDT virtual funds, more reliable).
# If you set this to "demo", fill in the DEMO keys below.
BYBIT_PAPER_BACKEND=testnet

# --- PAPER / TESTNET (safe, fake funds) ------------------------------------
# Create at: https://testnet.bybit.com  ->  API Management
BYBIT_TESTNET_KEY=
BYBIT_TESTNET_SECRET=

# --- PAPER / DEMO TRADING (safe, instant virtual funds) --------------------
# On the MAINNET site bybit.com, switch to "Demo Trading", then create API keys
# from INSIDE demo mode (they are separate from your real keys).
BYBIT_DEMO_KEY=
BYBIT_DEMO_SECRET=

# --- LIVE / MAINNET (REAL FUNDS — leave blank until you truly mean it) ------
# Create at: https://www.bybit.com  ->  API Management
# If these are blank, the app physically cannot go live.
BYBIT_MAINNET_KEY=
BYBIT_MAINNET_SECRET=

# --- Optional ---------------------------------------------------------------
# Where the SQLite db lives (default: ./data/trading.db)
# DB_PATH=./data/trading.db
